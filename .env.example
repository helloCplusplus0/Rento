# Rento-miniX 正式部署环境模板
# 复制为 .env 后，仅替换真实域名、私有密钥、管理员凭据与 PostgreSQL 连接串。

# 基础运行时
NODE_ENV=production
NEXTAUTH_URL=https://rento.example.com
ALLOWED_ORIGINS=https://rento.example.com

# 正式 Hono 运行时
# 正式部署默认由 Caddy 反向代理到本机环回端口。
MINIX_SERVER_HOST=127.0.0.1
MINIX_SERVER_PORT=3002
MINIX_DIST_DIR=dist

# 认证
# phase08 口径：AUTH_SESSION_SECRET 为正式主变量，
# NEXTAUTH_SECRET 仅保留历史兼容回退语义，不再作为主真相源传播。
AUTH_SESSION_SECRET=replace-with-a-secure-random-secret
NEXTAUTH_SECRET=replace-with-a-secure-random-secret
ADMIN_USERNAME=admin
# 生成命令：
# node -e "const { randomBytes, scryptSync } = require('node:crypto'); const password = process.argv[1]; const salt = randomBytes(16).toString('hex'); const hash = scryptSync(password, salt, 64).toString('hex'); console.log(`scrypt:${salt}:${hash}`)" "your-password"
ADMIN_PASSWORD_HASH=scrypt:replace-with-salt:replace-with-password-hash

# PostgreSQL
# 注意：如果密码包含 /、=、@ 等字符，连接串里必须做 URL 编码。
DATABASE_URL=postgresql://rento:YOUR_PASSWORD_URLENCODED@127.0.0.1:5432/rento_production

# 请求治理
CORS_ENABLED=true
MAX_REQUEST_SIZE=10485760
REQUEST_TIMEOUT=30000

# 迁移脚本兼容项
# phase10 已冻结：正式迁移目标仍是 `prisma migrate deploy`；
# `db push` 仅保留给当前 SQLite 历史残留命中的 compat path 兜底使用。
RUN_SEED=false
DB_WAIT_SECS=25

# 说明
# 1. `.env.example` 是唯一共享模板；`.env` 仍是服务器私有配置，不应提交到版本控制。
# 2. 正式部署主线固定为 `Caddy + systemd + Hono + PostgreSQL`，不再把容器镜像、Nginx、Redis 变量作为主模板矩阵。
# 3. `/api/health` 是唯一主健康入口；默认健康检查脚本会优先命中 `NEXTAUTH_URL`，否则回退到 `MINIX_SERVER_HOST:MINIX_SERVER_PORT`。
