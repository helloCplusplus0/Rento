# Rento 环境配置模板
# 复制此文件为 .env 后按实际环境修改

# ===========================================
# 基础配置
# ===========================================
# 开发态统一入口会在运行时强制使用 development；此处保留模板默认值用于容器 / 部署覆盖
NODE_ENV=production
HOST_IP=127.0.0.1
APP_INTERNAL_PORT=3001
APP_PORT=$APP_INTERNAL_PORT
CONTAINER_PREFIX=rento
NEXTAUTH_URL=http://$HOST_IP:$APP_PORT
# `phase05-05` 正式 PWA 验收时必须改为 HTTPS 私有域名，例如 https://rento.example.internal
# 若使用 Ubuntu 24 + Nginx + mkcert 的本地私有 HTTPS 验证方案：
# - 局域网 IP 示例：NEXTAUTH_URL=https://192.168.31.84
# - 私有主机名示例：NEXTAUTH_URL=https://rento.internal
# - 请配合 `nginx/templates/rento-local-https.conf.template`、
#   `nginx/templates/rento-local-https.env.example` 与
#   `scripts/pwa-local-https-helper.sh` 收口 Nginx 模板和本地验收入口
# 受控环境下显式开启最小 PWA / service worker；本地 `npm run dev` 默认不会注册
# 将其设为 0 可作为最小回退路径，使客户端重新访问后回到普通 Web 主线
NEXT_PUBLIC_ENABLE_PWA=0

# 当前最小门禁以 AUTH_SESSION_SECRET 为主真相源；NEXTAUTH_SECRET 仅保留兼容镜像
AUTH_SESSION_SECRET=replace-with-a-secure-random-secret
NEXTAUTH_SECRET=$AUTH_SESSION_SECRET

# ===========================================
# 管理员认证配置
# ===========================================
ADMIN_USERNAME=admin
# 使用以下命令生成：
# node -e "const { randomBytes, scryptSync } = require('node:crypto'); const password = process.argv[1]; const salt = randomBytes(16).toString('hex'); const hash = scryptSync(password, salt, 64).toString('hex'); console.log(`scrypt:${salt}:${hash}`)" "your-password"
ADMIN_PASSWORD_HASH=scrypt:replace-with-salt:replace-with-password-hash

# ===========================================
# PostgreSQL 配置
# ===========================================
# 注意：如果密码包含 /、=、@ 等字符，DATABASE_URL / CONTAINER_DATABASE_URL 中必须做 URL 编码
POSTGRES_DB=rento_production
POSTGRES_USER=rento
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_PORT=5432
# 宿主机开发、Prisma CLI、本地脚本统一使用宿主机映射端口
DATABASE_URL=postgresql://rento:YOUR_PASSWORD_URLENCODED@127.0.0.1:$POSTGRES_PORT/rento_production
# 容器内应用运行时统一使用服务名
CONTAINER_DATABASE_URL=postgresql://rento:YOUR_PASSWORD_URLENCODED@postgres:5432/rento_production

# ===========================================
# Redis / 其他服务
# ===========================================
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:$REDIS_PORT
CONTAINER_REDIS_URL=redis://redis:6379

# ===========================================
# 安全与网络
# ===========================================
# 正式 PWA 验收时应与 NEXTAUTH_URL 收口到同一 HTTPS 私有来源
# 本地私有 HTTPS 示例：
# - 局域网 IP：ALLOWED_ORIGINS=https://192.168.31.84
# - 私有主机名：ALLOWED_ORIGINS=https://rento.internal
# 若必须临时保留多个来源，正式验收来源也必须与 NEXTAUTH_URL 保持一致
ALLOWED_ORIGINS=http://$HOST_IP:$APP_PORT,http://localhost:$APP_PORT
CORS_ENABLED=true
# 当前代码以字节数解析，不接受 10mb 这类单位写法
MAX_REQUEST_SIZE=10485760
REQUEST_TIMEOUT=30000
HTTP_PORT=80
HTTPS_PORT=443

# ===========================================
# 监控、日志与健康检查
# ===========================================
ENABLE_MONITORING=true
PERFORMANCE_MONITORING=true
LOG_LEVEL=info
LOG_DIR=./logs
BACKUP_DIR=./backups
CONTAINER_LOG_DIR=/app/logs
CONTAINER_BACKUP_DIR=/app/backups
MEM_WARN_MB=512
MEM_FAIL_MB=1024
MAX_PERFORMANCE_METRICS=1000
SLOW_REQUEST_THRESHOLD=2000
BACKUP_RETENTION_DAYS=7

# ===========================================
# 告警与通知
# ===========================================
ENABLE_ALERTS=false
ALERT_EMAIL=
ALERT_WEBHOOK_URL=
SLACK_ALERT_CHANNEL=

# ===========================================
# 初始化与迁移
# ===========================================
RUN_SEED=false
DB_WAIT_SECS=25

# ===========================================
# 使用说明
# ===========================================
# 1. cp .env.example .env
# 2. 按需修改 HOST_IP / NEXTAUTH_URL / ALLOWED_ORIGINS / DATABASE_URL / CONTAINER_DATABASE_URL / POSTGRES_PASSWORD
# 3. 本地开发前先执行 npm run dev:check，再执行 npm run dev
# 4. 容器初始化时执行 podman-compose up -d
# 5. podman-compose exec app /app/scripts/migrate-and-seed.sh
#
# 当前项目统一使用 PostgreSQL，不再提供 SQLite 开发模板。
# 当前 migrations/ 目录仍带有 SQLite 历史兼容项；`migrate-and-seed.sh` 中的 `db push` 仅为过渡兜底，不代表正式 PostgreSQL 迁移基线。
# .env 属于本地私有配置文件，不应作为共享真相源。
# 端口占用排查指令：
#1. ps -ef | grep 'next dev --port 3001' | grep -v grep
#    ss -ltnp '( sport = :3001 )'
#2. kill PID1 PID2
#3. npm run dev
