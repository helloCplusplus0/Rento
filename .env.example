# Rento 环境配置模板
# 复制此文件为 .env 后按实际环境修改

# ===========================================
# 基础配置
# ===========================================
NODE_ENV=production
APP_INTERNAL_PORT=3001
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-with-a-secure-random-secret
AUTH_SESSION_SECRET=replace-with-a-secure-random-secret

# ===========================================
# 管理员认证配置
# ===========================================
ADMIN_USERNAME=admin
# 使用以下命令生成：
# node -e "const { randomBytes, scryptSync } = require('node:crypto'); const password = process.argv[1]; const salt = randomBytes(16).toString('hex'); const hash = scryptSync(password, salt, 64).toString('hex'); console.log(`scrypt:${salt}:${hash}`)" "your-password"
ADMIN_PASSWORD_HASH=scrypt:replace-with-salt:replace-with-password-hash

# ===========================================
# PostgreSQL 配置
# ===========================================
# 注意：如果密码包含 /、=、@ 等字符，DATABASE_URL 中必须做 URL 编码
DATABASE_URL=postgresql://rento:YOUR_PASSWORD@postgres:5432/rento_production
POSTGRES_DB=rento_production
POSTGRES_USER=rento
POSTGRES_PASSWORD=YOUR_PASSWORD

# ===========================================
# 安全与网络
# ===========================================
ALLOWED_ORIGINS=http://localhost:3001
CORS_ENABLED=true
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# ===========================================
# 监控与日志
# ===========================================
ENABLE_MONITORING=true
PERFORMANCE_MONITORING=true
LOG_LEVEL=info
BACKUP_DIR=/app/backups
LOG_DIR=/app/logs

# ===========================================
# 其他服务
# ===========================================
REDIS_URL=redis://redis:6379
# APP_PORT=3001
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# HTTP_PORT=80
# HTTPS_PORT=443

# ===========================================
# 使用说明
# ===========================================
# 1. cp .env.example .env
# 2. 按需修改 NEXTAUTH_URL / ALLOWED_ORIGINS / DATABASE_URL / POSTGRES_PASSWORD
# 3. podman-compose up -d
# 4. podman exec -it rento-app /app/scripts/migrate-and-seed.sh
#
# 当前项目统一使用 PostgreSQL，不再提供 SQLite 开发模板。
# .env 属于本地私有配置文件，不应作为共享真相源。
