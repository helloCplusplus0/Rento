# Rento 本地 HTTPS 模板变量示例
# 复制到宿主机私有路径后再修改，例如：
#   cp ./nginx/templates/rento-local-https.env.example ~/rento-local-https.env
#
# 该文件只用于渲染 Nginx 本地 HTTPS 模板，并为 专用 compose 文件 `docker-compose.local-https.yml` 提供证书路径变量。
# 应用运行时仍以仓库根目录 `.env` 为唯一环境真相源；compose 校验 / 启动时请与项目 `.env` 一起 source 到同一 shell 再执行 compose。
# 渲染后的最终配置默认写入 `./nginx/runtime/rento-local-https.conf`，供 compose 托管的本地 HTTPS Nginx 直接挂载。

# 支持两种长期入口：
# 1. 仅局域网 IP：PWA_LOCAL_HTTPS_SERVER_NAMES="192.168.x.x"
# 2. 私有主机名 + IP：PWA_LOCAL_HTTPS_SERVER_NAMES="rento.example.internal 192.168.x.x"
PWA_LOCAL_HTTPS_SERVER_NAMES="192.168.x.x rento.example.internal"

# mkcert 生成的宿主机私有证书路径，禁止提交进仓库。
PWA_LOCAL_HTTPS_CERT_PATH="/path/to/rento-local-certs/your-cert.pem"
PWA_LOCAL_HTTPS_KEY_PATH="/path/to/rento-local-certs/your-cert-key.pem"

# Nginx 反代到统一生产启动入口暴露的应用地址。
# 当前推荐保持 `http://127.0.0.1:${APP_INTERNAL_PORT}`，避免再次走错入口。
PWA_LOCAL_HTTPS_UPSTREAM_URL="http://127.0.0.1:3001"

# 本地 HTTPS Nginx 监听端口。默认使用 80/443；若 rootless Podman 无法绑定特权端口，可改为 8080/8443。
PWA_LOCAL_HTTPS_HTTP_LISTEN_PORT="80"
PWA_LOCAL_HTTPS_HTTPS_LISTEN_PORT="443"
